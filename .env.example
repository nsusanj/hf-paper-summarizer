# HuggingFace Paper Summarizer — Environment Variables
# Copy this file to .env and fill in the values you need.

# ── Prototyping (free) ──────────────────────────────────────────────────────
# Google Gemini API key — get one free at: https://aistudio.google.com
GOOGLE_API_KEY=

# ── Production (when ready to switch to Claude) ─────────────────────────────
# Anthropic API key — from https://console.anthropic.com
# Note: separate from your claude.ai Pro subscription
ANTHROPIC_API_KEY=

# ── Substack publishing ───────────────────────────────────────────────────────
# Your Substack login credentials (not stored in repo — add as GitHub secrets)
# If you signed up via Google/Apple SSO, set a password first in Substack settings.
SUBSTACK_EMAIL=
SUBSTACK_PASSWORD=
