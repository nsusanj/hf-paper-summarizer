# HuggingFace Paper Summarizer — Environment Variables
# Copy this file to .env and fill in the values you need.

# ── Prototyping (free) ──────────────────────────────────────────────────────
# Google Gemini API key — get one free at: https://aistudio.google.com
GOOGLE_API_KEY=

# ── Production (when ready to switch to Claude) ─────────────────────────────
# Anthropic API key — from https://console.anthropic.com
# Note: separate from your claude.ai Pro subscription
ANTHROPIC_API_KEY=

# ── Substack publishing ───────────────────────────────────────────────────────
# Browser session cookie string from a logged-in Substack session.
# To get it: DevTools (F12) → Network tab → any substack.com request → Copy "Cookie:" header value.
# Store as SUBSTACK_COOKIES in GitHub secrets. Re-extract when it expires (typically months).
SUBSTACK_COOKIES=
