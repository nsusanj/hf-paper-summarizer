# HuggingFace Paper Summarizer — Environment Variables
# Copy this file to .env and fill in the values you need.

# ── Prototyping (free) ──────────────────────────────────────────────────────
# Google Gemini API key — get one free at: https://aistudio.google.com
GOOGLE_API_KEY=

# ── Production (when ready to switch to Claude) ─────────────────────────────
# Anthropic API key — from https://console.anthropic.com
# Note: separate from your claude.ai Pro subscription
ANTHROPIC_API_KEY=

# ── Substack publishing ───────────────────────────────────────────────────────
# Use browser session cookies — bypasses Substack's login CAPTCHA and Cloudflare.
# Email/password auth is blocked by CAPTCHA even locally, so cookies are required.
#
# How to get your cookie string (one-time setup, lasts months):
#   1. Log into substack.com in your browser
#   2. Open DevTools (F12) → Network tab → refresh the page
#   3. Click any request to substack.com → Headers → find "Cookie:" under Request Headers
#   4. Copy the entire Cookie header value and paste it below
#
# For GitHub Actions: store this value as the SUBSTACK_COOKIES secret in the repo.
# For local use: set it here in .env.
SUBSTACK_COOKIES=
